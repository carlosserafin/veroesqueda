# ─────────────────────────────────────────────────────────────────────────────
# Vero Esqueda AI Specialist & Photo — variables de entorno
# Copiar a `.env.local` y rellenar valores reales. `.env.local` está en .gitignore.
# Las claves SIN prefijo NEXT_PUBLIC_ son server-only y NUNCA se exponen al cliente.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Sitio ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://veroesqueda.com
NEXT_PUBLIC_DEFAULT_LOCALE=es

# ─── Sony Alpha Partner badge (CLAUDE.md §9.2) ──────────────────────────────
# Apagar a `false` si Vero deja de ser Embajadora Sony Alpha Partner.
NEXT_PUBLIC_SONY_PARTNER_ACTIVE=true

# ─── Email transaccional (Resend) — formulario de contacto ──────────────────
RESEND_API_KEY=
CONTACT_TO_EMAIL=hola@veroesqueda.com
CONTACT_FROM_EMAIL=no-reply@veroesqueda.com

# ─── AI image generation (CLAUDE.md §17, build/dev-time únicamente) ─────────
# Server-only. Usadas desde scripts en `scripts/ai/`. Nunca expuestas al browser.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

GOOGLE_GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# ─── Analítica (opcional, privacy-first) ────────────────────────────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=veroesqueda.com
